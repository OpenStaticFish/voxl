---
import { site } from "../data/site";
---

<section id="pitch" class="pitch" aria-labelledby="pitch-title">
  <div class="grid-bg" aria-hidden="true"></div>
  <div class="wrap pitch-grid">
    <div class="pitch-copy">
      <p class="eyebrow">What is VOXL?</p>
      <h2 id="pitch-title">A pocket voxel sandbox that runs the moment you open it.</h2>
      <p>
        VOXL is a focused <strong>creative-mode slice</strong> of a voxel sandbox:
        spawn into a seeded world, walk or fly across four biomes, dig into a
        hillside, raise a tower, and capture the result. There's no crafting tree,
        no health bar, and no grinding — just terrain, blocks, and the tools to
        shape them.
      </p>
      <p>
        It's built as an original indie prototype with its own generated textures
        and identity. VOXL is <strong>not</strong> Minecraft, isn't affiliated with
        Mojang or Microsoft, and uses no copyrighted assets — everything you see is
        drawn in code.
      </p>
      <ul class="pitch-stats">
        <li>
          <span class="stat-n">{site.chunk}</span>
          <span class="stat-l">chunk columns</span>
        </li>
        <li>
          <span class="stat-n">4</span>
          <span class="stat-l">biomes</span>
        </li>
        <li>
          <span class="stat-n">23</span>
          <span class="stat-l">block types</span>
        </li>
      </ul>
    </div>

    <!-- Voxel cross-section: a blocky terrain slice, pure CSS. -->
    <div class="cross" role="img" aria-label="Diagram of a voxel terrain cross-section: grass and dirt over stone, with sand meeting water, a tree, and a cave opening.">
      <div class="cross-sky">
        <span class="cross-cloud"></span>
      </div>
      <div class="cross-grid" aria-hidden="true">
        <!-- Row by row, left to right voxels -->
        <i style="--c:var(--blk-grass)"></i><i style="--c:var(--blk-grass)"></i><i style="--c:var(--blk-grass)"></i><i style="--c:var(--blk-grass)"></i><i style="--c:var(--blk-sand)"></i><i class="water-top"></i><i class="water-top"></i><i class="water-top"></i>
        <i style="--c:var(--blk-dirt)"></i><i style="--c:var(--blk-dirt)"></i><i style="--c:var(--blk-dirt)"></i><i style="--c:var(--blk-dirt)"></i><i style="--c:var(--blk-sand)"></i><i class="water"></i><i class="water"></i><i class="water"></i>
        <i style="--c:var(--blk-dirt)"></i><i style="--c:var(--blk-dirt)"></i><i class="cave"></i><i style="--c:var(--blk-dirt)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i>
        <i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i class="cave"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i>
        <i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-stone)"></i><i style="--c:var(--blk-bedrock)"></i>
      </div>
      <!-- a little tree on top of the grass -->
      <span class="tree" aria-hidden="true">
        <span class="trunk"></span>
        <span class="leaves"></span>
      </span>
    </div>
  </div>
</section>

<style>
  .pitch {
    background: linear-gradient(180deg, var(--bg-0), var(--bg-1));
  }
  .pitch-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }
  .pitch-copy p {
    color: var(--ink-dim);
  }
  .pitch-copy strong {
    color: var(--ink);
  }
  .pitch-stats {
    list-style: none;
    margin: 1.6rem 0 0;
    padding: 0;
    display: flex;
    gap: clamp(16px, 4vw, 40px);
    flex-wrap: wrap;
  }
  .stat-n {
    display: block;
    font-family: var(--mono);
    font-size: 1.7rem;
    font-weight: 800;
    color: var(--grass);
    line-height: 1;
  }
  .stat-l {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--ink-mute);
  }

  /* cross-section diagram */
  .cross {
    position: relative;
    background: var(--panel-solid);
    border: 2px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    aspect-ratio: 8 / 6;
  }
  .cross-sky {
    height: 34%;
    background: linear-gradient(180deg, #16224a, #1d2c5c 70%, #243a72);
    position: relative;
  }
  .cross-cloud {
    position: absolute;
    top: 28%;
    right: 14%;
    width: 14px;
    height: 8px;
    background: rgba(220, 230, 255, 0.8);
    box-shadow: 9px 0 0 rgba(220, 230, 255, 0.8), 4px -8px 0 rgba(220, 230, 255, 0.8), 18px 0 0 rgba(220, 230, 255, 0.8);
  }
  .cross-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-auto-rows: 1fr;
    gap: 2px;
    padding: 2px;
    height: 66%;
    background: var(--border-soft);
  }
  .cross-grid i {
    display: block;
    background: var(--c, var(--blk-stone));
    box-shadow: inset 0 -6px 0 rgba(0, 0, 0, 0.18), inset 0 3px 0 rgba(255, 255, 255, 0.12);
  }
  .cross-grid .water {
    background: var(--blk-water);
    opacity: 0.85;
  }
  .cross-grid .water-top {
    background: #4a86e6;
    opacity: 0.9;
  }
  .cross-grid .cave {
    background: #0a0f1f;
    box-shadow: inset 0 0 0 2px rgba(0, 0, 0, 0.5);
  }
  .tree {
    position: absolute;
    top: 13%;
    left: 16%;
    width: 0;
    height: 0;
  }
  .trunk {
    position: absolute;
    left: -3px;
    top: 18px;
    width: 6px;
    height: 16px;
    background: var(--blk-wood);
    box-shadow: inset 0 -4px 0 rgba(0, 0, 0, 0.25);
  }
  .leaves {
    position: absolute;
    left: -12px;
    top: 0;
    width: 24px;
    height: 22px;
    background: var(--blk-leaves);
    box-shadow: inset 0 -6px 0 rgba(0, 0, 0, 0.25), inset 0 4px 0 rgba(255, 255, 255, 0.12);
    border-radius: 4px;
  }

  @media (max-width: 820px) {
    .pitch-grid {
      grid-template-columns: 1fr;
    }
    .cross {
      max-width: 460px;
    }
  }
</style>
