---
---

<section id="play" class="cta" aria-labelledby="cta-title">
  <div class="wrap cta-inner">
    <div class="cta-copy">
      <p class="eyebrow">Play now</p>
      <h2 id="cta-title">Play VOXL right in your browser</h2>
      <p class="lede">
        No install, no account — click play and the world loads in a
        dedicated full-screen view. Drop into a seeded world, survive the night,
        fly over the canopy, and start shaping terrain.
      </p>
      <div class="btn-row">
        <a class="btn btn--primary btn--lg" href="/play">▶ Play in browser</a>
        <a class="btn" href="/#controls">Read the controls</a>
      </div>
      <p class="req">
        Needs a desktop browser with <strong>WebGL</strong> &amp; pointer lock
        enabled.
      </p>
    </div>

    <details class="terminal-wrap">
      <summary>Prefer to run it from source? (Bun)</summary>
      <div class="terminal" role="region" aria-label="Commands to run VOXL locally">
        <p class="t-label">From the repository root</p>
        <ol class="t-list">
          <li>
            <span class="t-prompt">$</span>
            <code>git clone &lt;repo&gt; && cd voxl</code>
            <button class="copy" type="button" data-copy="git clone <repo> && cd voxl" aria-label="Copy command">copy</button>
          </li>
          <li>
            <span class="t-prompt">$</span>
            <code>bun install</code>
            <button class="copy" type="button" data-copy="bun install" aria-label="Copy command">copy</button>
          </li>
          <li>
            <span class="t-prompt">$</span>
            <code>bun run dev</code>
            <button class="copy" type="button" data-copy="bun run dev" aria-label="Copy command">copy</button>
          </li>
        </ol>
        <p class="t-note">Starts the game and the marketing site together. Then open the printed local URL in a modern desktop browser.</p>
      </div>
    </details>
  </div>
</section>

<style>
  .cta {
    background:
      radial-gradient(90% 120% at 80% 0%, rgba(55, 196, 106, 0.12), transparent 60%),
      linear-gradient(180deg, var(--bg-1), var(--bg-0));
  }
  .cta-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(28px, 5vw, 56px);
    align-items: center;
  }
  .btn--lg {
    padding: 0.95rem 1.5rem;
    font-size: 1.05rem;
  }
  .req {
    margin: 1rem 0 0;
    font-size: 0.85rem;
    color: var(--ink-mute);
    font-family: var(--mono);
  }
  .req strong {
    color: var(--ink-dim);
  }

  .terminal-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--panel-solid);
    padding: 0.2rem 1.1rem;
  }
  .terminal-wrap > summary {
    cursor: pointer;
    padding: 0.95rem 0;
    font-family: var(--mono);
    font-size: 0.92rem;
    color: var(--ink-dim);
    list-style: none;
  }
  .terminal-wrap > summary::-webkit-details-marker {
    display: none;
  }
  .terminal-wrap > summary::before {
    content: "▸ ";
    color: var(--teal);
  }
  .terminal-wrap[open] > summary::before {
    content: "▾ ";
  }

  .terminal {
    background: #070b1a;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1.1rem;
  }
  .t-label {
    margin: 0;
    padding: 0.6rem 1rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
    border-bottom: 1px solid var(--border-soft);
    background: var(--bg-2);
  }
  .t-list {
    list-style: none;
    margin: 0;
    padding: 0.3rem 0;
  }
  .t-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1rem;
    font-family: var(--mono);
    font-size: 0.92rem;
  }
  .t-list code {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0;
    color: var(--ink);
    word-break: break-all;
  }
  .t-prompt {
    color: var(--grass);
    user-select: none;
  }
  .copy {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-mute);
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .copy:hover {
    color: var(--teal);
    border-color: var(--teal);
  }
  .copy.copied {
    color: var(--grass);
    border-color: var(--grass);
  }
  .t-note {
    margin: 0;
    padding: 0 1rem 0.7rem;
    font-size: 0.82rem;
    color: var(--ink-mute);
  }

  @media (max-width: 820px) {
    .cta-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
