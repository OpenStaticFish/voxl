---
import { controls } from "../data/site";
---

<section id="controls" class="controls" aria-labelledby="controls-title">
  <div class="wrap controls-grid">
    <div class="controls-copy">
      <p class="eyebrow">Controls</p>
      <h2 id="controls-title">Play it like a sandbox</h2>
      <p class="lede">
        Standard FPS-style movement with pointer-lock mouse look. Walk with
        gravity, or double-tap <kbd>Space</kbd> to take off and fly free. The
        on-screen mode badge always tells you whether you're walking, flying or
        swimming.
      </p>
      <div class="control-tips">
        <div class="tip">
          <span class="tip-k"><kbd>Space</kbd> <kbd>Space</kbd></span>
          <span>Double-tap to toggle flight on and off.</span>
        </div>
        <div class="tip">
          <span class="tip-k"><kbd>P</kbd></span>
          <span>Capture a screenshot of the current view.</span>
        </div>
        <div class="tip">
          <span class="tip-k"><kbd>Esc</kbd></span>
          <span>Pause and release the mouse at any time.</span>
        </div>
      </div>
    </div>

    <div class="controls-table card" role="group" aria-labelledby="controls-title">
      <h3 class="visually-hidden">Full controls list</h3>
      <dl class="clist">
        {controls.map((c) => (
          <div class="crow">
            <dt class="ckeys">
              {c.keys.map((k) => <kbd>{k}</kbd>)}
            </dt>
            <dd class="cact">{c.action}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>

<style>
  .controls {
    background: var(--bg-0);
  }
  .controls-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(28px, 5vw, 56px);
    align-items: start;
  }
  .controls-copy .lede {
    margin-bottom: 1.6rem;
  }
  .control-tips {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .tip {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.95rem;
    color: var(--ink-dim);
  }
  .tip-k {
    flex: none;
    min-width: 132px;
  }

  .controls-table {
    padding: 0.4rem 0.6rem;
  }
  .clist {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
  }
  .crow {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.6rem 0.8rem;
    border-bottom: 1px solid var(--border-soft);
  }
  .crow:last-child {
    border-bottom: none;
  }
  .ckeys {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    flex: none;
    min-width: 120px;
  }
  .cact {
    margin: 0;
    color: var(--ink-dim);
    font-size: 0.95rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 820px) {
    .controls-grid {
      grid-template-columns: 1fr;
    }
    .tip-k {
      min-width: 0;
    }
  }
</style>
