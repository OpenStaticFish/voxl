---
import { status, site } from "../data/site";

const done = status.filter((s) => s.done);
const todo = status.filter((s) => !s.done);
---

<section id="status" class="status" aria-labelledby="status-title">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">Project status</p>
      <h2 id="status-title">What works today, v{site.version}</h2>
      <p class="lede">
        VOXL is an original indie engine, not a finished commercial game. Here's
        exactly what's live right now and what's next on the build — the full
        phased plan lives on the roadmap.
      </p>
    </div>

    <div class="status-cols">
      <div class="status-col card">
        <h3><span class="status-dot status-dot--done" aria-hidden="true"></span> Live now</h3>
        <ul class="status-list">
          {done.map((s) => (
            <li class="ok">{s.label}</li>
          ))}
        </ul>
      </div>
      <div class="status-col card">
        <h3><span class="status-dot status-dot--todo" aria-hidden="true"></span> Coming next</h3>
        <ul class="status-list">
          {todo.map((s) => (
            <li class="no">{s.label}</li>
          ))}
        </ul>
        <p class="status-foot">
          These are the nearest milestones on a longer journey to a full sandbox.
          See the whole plan — crafting, mobs, advanced biomes and multiplayer —
          on the <a href="/roadmap">roadmap</a>.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .status {
    background: var(--bg-0);
  }
  .status-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(16px, 2.5vw, 26px);
  }
  .status-col h3 {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0;
  }
  .status-dot {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    box-shadow: inset 0 -4px 0 rgba(0, 0, 0, 0.25);
  }
  .status-dot--done {
    background: var(--grass);
  }
  .status-dot--todo {
    background: var(--amber);
  }
  .status-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
    font-size: 0.95rem;
    color: var(--ink-dim);
  }
  .status-list li {
    padding-left: 1.6rem;
    position: relative;
  }
  .status-list li::before {
    position: absolute;
    left: 0;
    top: 1px;
    font-family: var(--mono);
    font-weight: 800;
  }
  .status-list .ok::before {
    content: "✓";
    color: var(--grass);
  }
  .status-list .no::before {
    content: "○";
    color: var(--amber);
  }
  .status-foot {
    margin: 1rem 0 0;
    color: var(--ink-mute);
    font-size: 0.88rem;
    border-top: 1px solid var(--border-soft);
    padding-top: 0.9rem;
  }
  @media (max-width: 720px) {
    .status-cols {
      grid-template-columns: 1fr;
    }
  }
</style>
