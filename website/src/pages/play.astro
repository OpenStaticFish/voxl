---
import BaseHead from "../components/BaseHead.astro";
import { site } from "../data/site";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Play ${site.name}`} description={`Play ${site.name}, a browser-based WebGL voxel sandbox, right in your browser.`} />
    <meta name="robots" content="noindex" />
  </head>
  <body class="play-body">
    <header class="play-bar">
      <a class="back" href="/">
        <span aria-hidden="true">←</span> Back to site
      </a>
      <a class="brand-mini" href="/" aria-label={`${site.name} home`}>
        <strong>VOXL</strong>
        <span class="v">v{site.version}</span>
      </a>
      <a class="help" href="/#controls">Controls <span aria-hidden="true">↗</span></a>
    </header>

    <main class="play-stage">
      <!--
        The game is a self-contained WebGL app (built from the repo root and
        synced into /game/). It needs pointer lock + fullscreen to feel right,
        so we embed it same-origin in an iframe with the relevant permissions.
      -->
      <iframe
        id="game"
        title={`${site.name} game`}
        src="/game/index.html"
        loading="eager"
        allow="fullscreen; pointer-lock; autoplay; gamepad; cross-origin-isolated"
        allowfullscreen
      ></iframe>

      <!-- Loading veil, removed once the iframe has loaded. -->
      <div id="veil" class="veil" role="status" aria-live="polite">
        <div class="spinner" aria-hidden="true"></div>
        <p>Loading {site.name}…</p>
        <p class="veil-hint">Needs a desktop browser with WebGL + pointer lock.</p>
      </div>
    </main>

    <noscript>
      <p class="noscript">{site.name} needs JavaScript &amp; WebGL to run.</p>
    </noscript>

    <script>
      const frame = document.getElementById("game") as HTMLIFrameElement | null;
      const veil = document.getElementById("veil");
      if (frame && veil) {
        const hide = () => {
          veil.classList.add("veil--hidden");
          // Hand focus to the iframe so keyboard input works immediately.
          window.setTimeout(() => {
            try {
              frame.contentWindow?.focus();
            } catch {
              /* cross-origin isolation differences are fine */
            }
          }, 150);
        };
        frame.addEventListener("load", hide);
        // Safety net: some browsers fire `load` before the canvas is ready.
        window.setTimeout(hide, 4000);
      }
    </script>

    <style is:global>
      html,
      body {
        margin: 0;
        height: 100%;
        background: var(--bg-0, #0b1020);
        overflow: hidden;
      }
    </style>

    <style>
      .play-body {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        font-family: var(--sans);
        color: var(--ink);
      }
      .play-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.5rem 1rem;
        background: rgba(8, 12, 28, 0.9);
        border-bottom: 1px solid var(--border, #2a355a);
        font-family: var(--mono);
        font-size: 0.85rem;
        flex: none;
      }
      .play-bar a {
        color: var(--ink-dim, #9aa6cc);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3ch;
        padding: 0.4rem 0.7rem;
        border-radius: 8px;
        border: 1px solid transparent;
        transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
      }
      .play-bar a:hover {
        color: var(--ink, #e8edff);
        background: var(--bg-2, #1b2444);
        border-color: var(--border, #2a355a);
      }
      .brand-mini {
        font-weight: 800;
        letter-spacing: 0.14em;
        color: var(--ink) !important;
      }
      .brand-mini .v {
        font-size: 0.66rem;
        color: var(--ink-mute, #6b78a0);
        margin-left: 0.4rem;
        border: 1px solid var(--border, #2a355a);
        padding: 0.1rem 0.4rem;
        border-radius: 6px;
      }
      .help {
        margin-left: auto;
      }

      .play-stage {
        position: relative;
        flex: 1 1 auto;
        min-height: 0;
        background: #06091a;
      }
      #game {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
        display: block;
      }

      .veil {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        text-align: center;
        background: radial-gradient(80% 80% at 50% 40%, #0c1430, #06091a);
        font-family: var(--mono);
        color: var(--ink-dim, #9aa6cc);
        transition: opacity 0.25s ease;
      }
      .veil--hidden {
        opacity: 0;
        pointer-events: none;
      }
      .veil-hint {
        font-size: 0.78rem;
        color: var(--ink-mute, #6b78a0);
      }
      .spinner {
        width: 42px;
        height: 42px;
        border: 4px solid rgba(255, 255, 255, 0.12);
        border-top-color: var(--grass, #37c46a);
        border-radius: 50%;
        animation: spin 0.9s linear infinite;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .spinner {
          animation-duration: 2s;
        }
      }

      .noscript {
        position: fixed;
        inset: 0;
        margin: 0;
        display: grid;
        place-items: center;
        background: #06091a;
        color: var(--ink-dim, #9aa6cc);
        font-family: var(--mono);
      }

      @media (max-width: 560px) {
        .help {
          display: none;
        }
      }
    </style>
  </body>
</html>
