# Version control
.git
.gitignore
.gitattributes

# Dependencies — regenerated inside the image, never copy host's in.
**/node_modules

# Build outputs — regenerated by the build stages.
dist
**/dist
out

# Astro generated cache (would break nothing, just bloat)
website/.astro

# Synced game build — regenerated by `bun run sync:game`.
website/public/game

# Env files (never bake secrets into images)
.env
.env.*

# Editor / OS noise
.idea
.vscode
.DS_Store
*.swp

# Benchmark prompts/artifacts (kept out of the public repo)
mineclone.md
website.md
screenshots/

# Logs
*.log
npm-debug.log*
